{
  "expo": {
    "name": "Teswa",
    "slug": "teswa-mobile",
    "scheme": "teswa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "edgeToEdgeEnabled": true,
      "package": "com.teswa.mobile"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "نحتاج الوصول للصور لاختيار صور العنصر قبل نشره.",
          "microphonePermission": false
        }
      ]
    ]
  }
}
